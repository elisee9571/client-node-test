<%- include("../partials/_header") %>

    <main class="w-50 m-auto">
        <form action="" method="post">
            <h1 class="h3 mb-3 fw-normal">Please sign up</h1>

            <div class="mb-3">
                <label for="input-name">Name</label>
                <input type="text" name="name" class="form-control <%= fieldErrors && fieldErrors.name ? 'is-invalid' : '' %>" id="input-name" placeholder="John Doe" value="<%= values && values.name ? values.name : '' %>">

                <% if (fieldErrors && fieldErrors.name) { %>
                    <div class="invalid-feedback">
                        <%= fieldErrors.name %>
                    </div>
                <% } %>
            </div>

            <div class="mb-3">
                <label for="input-email">Email address</label>
                <input type="email" name="email" class="form-control <%= fieldErrors && fieldErrors.email ? 'is-invalid' : '' %>" id="input-email" placeholder="name@example.com" value="<%= values && values.email ? values.email : '' %>">

                <% if (fieldErrors && fieldErrors.email) { %>
                    <div class="invalid-feedback">
                        <%= fieldErrors.email %>
                    </div>
                <% } %>
            </div>

            <div class="mb-3"> 
                <label for="input-password">Password</label>
                <input type="password" name="password" class="form-control <%= fieldErrors && fieldErrors.password ? 'is-invalid' : '' %>" id="input-password" placeholder="************">

                <% if (fieldErrors && fieldErrors.password) { %>
                    <div class="invalid-feedback">
                        <%= fieldErrors.password %>
                    </div>
                <% } %>
            </div>

            <button class="btn btn-primary w-100 py-2" type="submit">Sign up</button>
        </form>
    </main>

<%- include("../partials/_footer") %>